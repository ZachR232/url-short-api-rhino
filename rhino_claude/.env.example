# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_DB=urlshortener
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme          # use a strong password in production

# API
BASE_URL=http://localhost:8000      # public-facing base URL for generated short links
API_PORT=8000                       # host port to bind (change if 8000 is taken)
CACHE_TTL_SECONDS=3600              # how long short codes stay in Redis cache
